{
  "name": "discord-event-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Bot Discord avançado para gestão de eventos com PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "deploy-commands:global": "tsx src/deploy-commands-global.ts",
    "migrate": "tsx src/database/run-migrate.ts",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "discord",
    "bot",
    "events",
    "postgresql"
  ],
  "license": "MIT",
  "author": "Samuel (hiro)",
  "repository": {
    "type": "git",
    "url": "https://github.com/bughir0/Discord-Event-Register-Bot.git"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

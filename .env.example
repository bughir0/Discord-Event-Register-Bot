# Token do bot (Discord Developer Portal > Bot)
DISCORD_TOKEN=

# ID da aplicação (Client ID) — necessário para registrar comandos slash
DISCORD_CLIENT_ID=

# ID do servidor para deploy rápido de comandos (guild). Deixe vazio para comandos globais.
DISCORD_GUILD_ID=

# true = npm run deploy-commands regista sempre comandos GLOBAIS (útil se DISCORD_GUILD_ID estiver preenchido)
DISCORD_GLOBAL_COMMANDS=

# PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/discord_events

# IDs de cargos que podem usar comandos de staff (separados por vírgula). Se vazio, usa permissão Gerenciar Servidor
STAFF_ROLE_IDS=

# IDs de cargos de admin (relatórios sensíveis, exportação). Se vazio, apenas ManageGuild
ADMIN_ROLE_IDS=

# Canal opcional para espelhar logs administrativos (ID do canal)
ADMIN_LOG_CHANNEL_ID=

# Intents: no Developer Portal ative MESSAGE CONTENT INTENT para contar mensagens em canais
